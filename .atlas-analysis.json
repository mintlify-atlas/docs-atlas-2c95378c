  "keyFeatures": [
    "Interactive mathematical challenges with MathLive input",
    "Multi-tiered competition system (regular and summer competitions)",
    "Key stage separated leaderboards (KS3, KS4, KS5)",
    "Advanced math expression evaluation engine with LaTeX support",
    "School-based competition tracking",
    "Content management for articles and newsletters",
    "Admin dashboard for user and challenge management",
    "Scheduled challenge releases with time-based locking",
    "Real-time submission validation and scoring"
  ],
  "publicApiSurface": [
    "User authentication (login, register, logout)",
    "Challenge submission and validation",
    "Leaderboard viewing (overall and summer competition)",
    "Article and newsletter browsing",
    "Profile management",
    "Admin panel operations (user/challenge/article CRUD)",
    "Mathematical expression comparison API",
    "Health and readiness endpoints (/healthz, /readyz)"
  ]
